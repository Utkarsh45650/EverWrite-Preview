# =========================
# EverWrite Environment
# Copy values into .env for local run
# =========================

# --- Flask Runtime ---
FLASK_HOST=127.0.0.1
FLASK_PORT=8000
FLASK_DEBUG=true
FLASK_SECRET_KEY=replace-with-a-long-random-secret

# Comma-separated origins for browser access to /api/*
# Example: http://localhost:5173,http://127.0.0.1:3000
CORS_ORIGINS=

# If frontend is hosted separately, set full backend URL.
# Keep empty when serving frontend from Flask itself.
FRONTEND_API_BASE_URL=

# --- AI / LLM ---
# Primary provider: Groq. Ollama remains available as a local fallback.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

GENERATION_TEMPERATURE=0.7
GENERATION_MAX_OUTPUT_TOKENS=6000
GROQ_MAX_CONTINUATIONS=1

# --- Memory / Retrieval ---
TOP_K=5
EMBEDDING_MODEL=all-MiniLM-L6-v2
CHROMA_PERSIST_DIR=chroma_db
